# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Visitor access cookie
VISITOR_COOKIE_NAME=visitor_access
VISITOR_COOKIE_SECRET=your-random-secret-at-least-32-chars-long

# Storage
NEXT_PUBLIC_SUPABASE_STORAGE_URL=https://<project>.supabase.co/storage/v1
